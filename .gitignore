# .gitignore for V-Model XT Medical Device Project

# Build artifacts (also inside src/ components)
build/
**/build/
bin/
lib/
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
moc_*.cpp
qrc_*.cpp
ui_*.h

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Qt Creator
*.pro.user
*.pro.user.*

# Python
__pycache__/
*.pyc
.venv/

# Node (if dashboard has deps)
node_modules/

# Temporary files
*~
*.tmp
*.bak
Thumbs.db
~$*.docx
~$*.xlsx
~$*.pptx

# Dashboard data (runtime — regenerated by validator/gate engine/dashboard scripts)
dashboard/data/status.json
dashboard/data/project.json
dashboard/data/history.json
dashboard/data/validation.json
dashboard/data/gates.json
dashboard/data/reports/
!dashboard/data/reports/.gitkeep

# Secrets
.env
*.pem
*.key
